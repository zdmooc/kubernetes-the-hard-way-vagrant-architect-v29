apiVersion: v1
kind: Config
clusters:
  - name: kubernetes-the-hard-way
    cluster:
      certificate-authority: /etc/kubernetes/pki/ca.pem
      server: https://192.168.56.10:6443
contexts:
  - name: default
    context:
      cluster: kubernetes-the-hard-way
      user: worker-0
current-context: default
users:
  - name: worker-0
    user:
      client-certificate: /etc/kubernetes/pki/worker-0.pem
      client-key: /etc/kubernetes/pki/worker-0-key.pem
